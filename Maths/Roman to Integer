Problem: Roman to Integer
LeetCode #13
Approach: Traverse from right to left and use subtraction rule
Time Complexity: O(n)
Space Complexity: O(1)

#include <string>
#include <unordered_map>
using namespace std;

class Solution {
public:
    int romanToInt(string s) {

        unordered_map<char, int> mp = {
            {'I', 1}, {'V', 5}, {'X', 10},
            {'L', 50}, {'C', 100},
            {'D', 500}, {'M', 1000}
        };

        int total = 0;
        int prev = 0;

        // Traverse from right to left
        for (int i = s.size() - 1; i >= 0; i--) {

            int curr = mp[s[i]];

            // If current value is less than previous, subtract
            if (curr < prev) {
                total -= curr;
            } else {
                total += curr;
            }

            prev = curr;
        }

        return total;
    }
};
