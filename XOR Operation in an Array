Problem: XOR Operation in an Array
LeetCode #1486
Approach: Iterate and XOR all generated elements
Time Complexity: O(n)
Space Complexity: O(1)

class Solution {
public:
    int xorOperation(int n, int start) {
        
        int result = 0;

        // Generate elements and XOR them
        for (int i = 0; i < n; i++) {
            result ^= (start + 2 * i);
        }

        return result;
    }
};
