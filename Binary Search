Problem: Single Number
LeetCode #136
Approach: Bit Manipulation (XOR)
Time Complexity: O(n)
Space Complexity: O(1)

#include <vector>
using namespace std;

class Solution {
public:
    int singleNonDuplicate(vector<int>& nums) {

        int ans = 0;

        
        for (int num : nums) {
            ans ^= num;
        }

        return ans;
    }
};
