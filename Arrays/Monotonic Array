Problem: Monotonic Array
LeetCode #896
Approach: Check if array is either entirely non-increasing or non-decreasing
Time Complexity: O(n)
Space Complexity: O(1)

#include <vector>
using namespace std;

class Solution {
public:
    bool isMonotonic(vector<int>& nums) {
        int direction = 0; // 0 = unknown, 1 = increasing, -1 = decreasing

        for (int i = 1; i < nums.size(); i++) {
            if (nums[i] > nums[i - 1]) {
                if (direction == -1) return false;
                direction = 1;
            }
            else if (nums[i] < nums[i - 1]) {
                if (direction == 1) return false;
                direction = -1;
            }
        }

        return true;
    }
};
