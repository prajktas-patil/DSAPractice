Problem: Array Partition I
LeetCode #561
Approach: Sort the array and sum every alternate element
Time Complexity: O(n log n) (due to sorting)
Space Complexity: O(1)

#include <vector>
#include <algorithm>
using namespace std;

class Solution {
public:
    int arrayPairSum(vector<int>& nums) {

        // Step 1: Sort the array
        sort(nums.begin(), nums.end());

        int sum = 0;

        // Step 2: Sum every alternate element (minimum in each pair)
        for (int i = 0; i < nums.size(); i += 2) {
            sum += nums[i];
        }

        return sum;
    }
};
