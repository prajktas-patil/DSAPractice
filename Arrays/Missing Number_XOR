Problem: Missing Number
LeetCode #268
Approach: XOR Technique
Time Complexity: O(n)
Space Complexity: O(1)

#include <vector>
using namespace std;

class Solution {
public:
    int missingNumber(vector<int>& nums) {
        int xorval=nums.size();
        for(int i=0;i<nums.size();i++)
        {
            xorval=xorval^i^nums[i];
           
        }
         return xorval;
    }
};
