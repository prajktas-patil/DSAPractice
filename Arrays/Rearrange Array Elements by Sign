Problem: Rearrange Array Elements by Sign
LeetCode #2149
Approach: Place positive numbers at even indices and negative numbers at odd indices
Time Complexity: O(n)
Space Complexity: O(n)

#include <vector>
using namespace std;

class Solution {
public:
    vector<int> rearrangeArray(vector<int>& nums) {

        int n = nums.size();
        vector<int> ans(n, 0);

        int posIndex = 0; // even index for positive numbers
        int negIndex = 1; // odd index for negative numbers

        for (int i = 0; i < n; i++) {

            if (nums[i] < 0) {
                ans[negIndex] = nums[i];
                negIndex += 2;
            } 
            else {
                ans[posIndex] = nums[i];
                posIndex += 2;
            }
        }

        return ans;
    }
};
