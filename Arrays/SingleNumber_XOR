Problem: Single Number in Array
Leetcode: 136
Category: Array / Bit Manipulation

Approach:
- Use XOR to cancel out duplicate numbers
- XOR of a number with itself is 0
- XOR of a number with 0 is the number itself

Time Complexity: O(n)
Space Complexity: O(1)

#include<iostream>
#include <vector>
using namespace std;

class solution 
{
  int singleNumber(int<vector>& nums)
  {
    int ans=0;
    for( int val:nums) //here i accessed each element from array nums
    {
      ans^=val;
    }
    return ans;
  }
};
   


