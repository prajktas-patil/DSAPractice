
Problem: Move Zeroes
Platform: LeetCode

Goal:
Move all zeroes to the end of the array while maintaining
the relative order of the non-zero elements.

Approach:
1. Find the first zero index.
2. Traverse the array from that point.
3. Whenever a non-zero element is found, swap it with the zero index.
4. Move the zero index forward.

Time Complexity: O(n)
Space Complexity: O(1)


class Solution {
public:
    void moveZeroes(vector<int>& nums) {

        int j = -1;

       
        for(int i = 0; i < nums.size(); i++) {
            if(nums[i] == 0) {
                j = i;
                break;
            }
        }

        
        if(j == -1) return;

        for(int i = j + 1; i < nums.size(); i++) {
            if(nums[i] != 0) {
                swap(nums[i], nums[j]);
                j++;
            }
        }
    }
};
